# Raw IMU Accelerometer Data (m/s^2)
float32 accel_x
float32 accel_y
float32 accel_z

# Raw IMU Gyroscope Data (rad/s)
float32 gyro_x
float32 gyro_y
float32 gyro_z

# Altitude Sensors
float32 tof_distance      # Distance from ToF in meters
float32 baro_pressure     # Pressure from Barometer in Pascals